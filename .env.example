# Conexión Backend (Requerido)
URL_BACKEND=https://api.tudominio.com
URL_SIGNALING=wss://api.tudominio.com/ws/vehiculo/

# Token de Vinculación (Solo para el primer uso)
BARCO_TOKEN_VINCULACION=XYZ-123

# Configuración WebRTC / Red (Opcional pero CRITICO para 4G)
# Si usas 4G (Entel/Claro/Movistar), necesitas un servidor TURN 
# porque STUN no suele funcionar detrás de CGNAT estricto.
SERVIDOR_STUN=stun:stun.l.google.com:19302
SERVIDOR_TURN_URL=turn:turn.tudominio.com:3478
SERVIDOR_TURN_USER=usuario_turn
SERVIDOR_TURN_PASS=password_turn

# Configuración Hardware
CAMARA_FPS=15
CAMARA_ANCHO=640
CAMARA_ALTO=480
LOG_LEVEL=INFO
